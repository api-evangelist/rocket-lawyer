        {
          "id": "5f226172-4f2c-4a51-8c92-57bab42e4247",
          "name": "delete Subscription",
          "request": {
            "name": "delete Subscription",
            "description": {
              "content": "Delete a subscription. This will cause the acknowledgement state of all events to be\nforgotten. If you wish to \"undo\" a deletion, you may create a new subscription and\nperform a seek request to just before the time of deletion, though you must be\nprepared to handle a few duplicate events.\n<br/><br/>\nAuthorization\\: Requires a general access or scoped access token.\n",
