        "params": [
          {
            "name": "documentId",
            "value": "",
            "type": "path"
          },
          {
            "name": "binderId",
            "value": "",
            "type": "path"
          }
        ]
      },
      "docs": "<b>Allowed roles:</b> FRONTEND (OWNER only), BACKEND<br/>\nUploads content of document\n"
    },
    {
      "info": {
        "name": "PATCH_binders-binderId-documents-documentId",
        "type": "http"
      },
      "http": {
        "method": "PATCH",
        "url": "https://api-sandbox.rocketlawyer.com/document-manager/v1/binders/:binderId/documents/:documentId",
        "headers": [
          {
            "name": "Content-Type",
