            "type": "path"
          }
        ],
        "body": {
          "type": "json",
          "data": "{}"
        }
      },
      "docs": "<b>Allowed roles:</b> BACKEND <br/>\nCreates of lock preventing certain actions on the binder. In example having a cancellation lock on a binder will prevent signing from being cancelled.\n"
    },
    {
