            "name": "binderId",
            "value": "",
            "type": "path"
          }
        ]
      },
      "docs": "<b>Allowed roles:</b> BACKEND <br/>\nDelete a lock from the binder.\nLocks can be deleted only by the client that acquired the lock\n"
    },
    {
      "info": {
        "name": "GET_binders-binderId-parties",
        "type": "http"
